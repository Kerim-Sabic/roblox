{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nectarpilot.dev/schemas/soak-result.schema.json",
  "title": "NectarPilot soak result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "mode",
    "build_commit",
    "profile_digest",
    "heartbeat_sha256",
    "heartbeat_count",
    "safe_profile_validated",
    "channel",
    "started_at",
    "finished_at",
    "duration_hours",
    "passed",
    "unhandled_crashes",
    "stuck_inputs",
    "unrelated_process_terminations",
    "false_roblox_restarts",
    "forced_recovery_scenarios",
    "approved_by"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "mode": { "const": "live" },
    "build_commit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
    "profile_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "heartbeat_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "heartbeat_count": { "type": "integer", "minimum": 2 },
    "safe_profile_validated": { "const": true },
    "channel": { "enum": ["beta", "stable"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "duration_hours": { "type": "number", "minimum": 0 },
    "passed": { "type": "boolean" },
    "unhandled_crashes": { "type": "integer", "minimum": 0 },
    "stuck_inputs": { "type": "integer", "minimum": 0 },
    "unrelated_process_terminations": { "type": "integer", "minimum": 0 },
    "false_roblox_restarts": { "type": "integer", "minimum": 0 },
    "forced_recovery_scenarios": { "type": "integer", "minimum": 0 },
    "severity_1_open": { "type": "integer", "minimum": 0, "default": 0 },
    "severity_2_open": { "type": "integer", "minimum": 0, "default": 0 },
    "approved_by": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  }
}
